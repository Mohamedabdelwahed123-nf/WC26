# ---- Base de données (Neon PostgreSQL) ----
# Chaîne de connexion "pooled" (host avec "-pooler") depuis neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ---- NextAuth ----
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="remplace-par-une-cle-aleatoire"
# En local : http://localhost:3000 — en prod : https://ton-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ---- Inscription privée (partage ce code à tes amis) ----
INVITE_CODE="MONDIAL26"

# ---- Compte admin (créé par npm run db:seed) ----
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="remplace-par-un-mot-de-passe-fort"

# ---- Cron Vercel ----
# Générer avec : openssl rand -base64 32
CRON_SECRET="remplace-par-un-secret-cron"
